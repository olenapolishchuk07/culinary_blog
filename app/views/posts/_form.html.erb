<div class="editor__card">
  <% if post.errors.any? %>
    <div class="flash flash--alert">
      <strong>Будь ласка, виправ помилки:</strong>
      <ul>
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title, "Назва страви / Заголовок", class: "field__label" %>
    <%= f.text_field :title, placeholder: "Що готуємо сьогодні?...", class: "field__input" %>
  </div>

  <div class="field">
    <%= f.label :category, "Категорія", class: "field__label" %>
    <%= f.select :category,
        Post::CATEGORIES.map { |k, v| [v, k] },
        {},
        class: "field__input" %>
  </div>

  <div class="field">
    <%= f.label :body, "Опис / Рецепт", class: "field__label" %>
    <%= f.text_area :body, rows: 8,
        placeholder: "Опишіть процес приготування або ваші враження...",
        class: "field__input" %>
  </div>

  <div class="field">
    <%= f.label :tags, class: "field__label" do %>
      Теги <span class="field__hint">(через кому: курка, часник, паприка)</span>
    <% end %>
    <%= f.text_field :tags, placeholder: "курка, картопля, розмарин", class: "field__input" %>
  </div>

  <div class="editor__actions">
    <%= link_to "Скасувати", posts_path, class: "btn" %>
    <%= f.submit class: "btn btn--primary" %>
  </div>
</div>
